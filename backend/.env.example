FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# PostgreSQL connection for future user accounts and conversation history
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=umai
POSTGRES_USER=umai
POSTGRES_PASSWORD=change-me

# OpenRouter settings (required for LLM integration)
# Get an API key from OpenRouter and paste it here. Never commit it.
LLM_API_KEY=

# RAG settings
RAG_DOCS_DIR=cuisine_pdf
RAG_VECTOR_STORE_DIR=instance/rag/faiss_index
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=4
