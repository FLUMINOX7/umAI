FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# PostgreSQL connection for future user accounts and conversation history
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=umai
POSTGRES_USER=umai
POSTGRES_PASSWORD=change-me

# OpenRouter settings (required for LLM integration)
# Get an API key from OpenRouter and paste it here. Never commit it.
LLM_API_KEY=
# Default model to use at provider side (change if needed)
LLM_MODEL=mistralai/mistral-7b-instruct

# Provider choice: auto, openrouter, or ollama
LLM_PROVIDER=auto

# Ollama local settings (used when provider is ollama or when auto falls back)
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.1
